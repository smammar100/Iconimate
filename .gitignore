# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
# machine-local pnpm config (store/cache paths differ per machine)
/.npmrc
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# generated shadcn registry (rebuilt by scripts/build-registry.mjs on dev/build)
/public/r/
/generated/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code scratch workflow scripts (kept local)
.claude/wf-*.js

# Agent tooling installed via `npx skills add` — dev tooling, not the product
/.agents/
/.claude/skills/
/skills-lock.json

# Motion guide — the project's private "brain"; kept local, never published
registry/MOTION.md
