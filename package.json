{
  "name": "iconimate-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/build-registry.mjs && next dev --webpack",
    "build": "node scripts/build-registry.mjs && next build --webpack",
    "build:registry": "node scripts/build-registry.mjs",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit && tsc -p scripts/tsconfig.registry.json --noEmit",
    "test": "node --test \"scripts/**/*.test.mjs\"",
    "verify": "pnpm build:registry && pnpm typecheck && pnpm lint && pnpm test"
  },
  "dependencies": {
    "@react-spectrum/s2": "^1.4.0",
    "@vercel/analytics": "^2.0.1",
    "border-beam": "^1.3.0",
    "geist": "^1.7.2",
    "motion": "^12.42.2",
    "next": "16.2.10",
    "ogl": "^1.0.11",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "unplugin-parcel-macros": "^0.2.0"
  },
  "pnpm": {
    "overrides": {
      "postcss@<8.5.10": ">=8.5.10"
    }
  }
}
